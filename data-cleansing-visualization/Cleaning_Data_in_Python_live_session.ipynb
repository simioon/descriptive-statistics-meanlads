      "source": [
        "# Visualize relationship between price and room_type\n",
        "sns.boxplot(x = 'room_type', y = 'price', data = airbnb)\n",
        "plt.ylim(0, 400)\n",
        "plt.xlabel('Room Type')\n",
        "plt.ylabel('Price')\n",
        "plt.show()"
      ]
